# 火山引擎 (豆包) API 配置
# 请将此文件重命名为 .env，并填入你自己的真实数据

# 1. 你的 API Key (在火山引擎控制台 -> API Key 管理中生成)
VITE_DOUBAO_API_KEY="sk-你的真实API_KEY"

# 2. 你的推理接入点 ID (Endpoint ID)
# 必须使用在“在线推理”中创建的接入点 ID，格式类似 ep-20240101010101-abcde
VITE_DOUBAO_MODEL_EP="ep-你的真实接入点ID"

# 3. 基础地址 (通常不需要改动，保持默认即可)
VITE_DOUBAO_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
